name: CI/CD

on:
  push:
    branches: [main]

jobs:
  build-and-deploy:
    runs-on: ubuntu-latest

    steps:
      - uses: actions/checkout@v4

      - name: Lint
        run: |
          {% if language == "python" %}
          pip install flake8
          flake8 . --max-line-length=120 --exclude=.git,__pycache__
          {% else %}
          npm install
          npm run lint --if-present
          {% endif %}

      - name: Test
        run: |
          {% if language == "python" %}
          pip install -r requirements.txt
          python -m pytest --tb=short || true
          {% else %}
          npm ci
          npm test --if-present || true
          {% endif %}

      {% if cloud %}
      - name: Configure AWS credentials
        uses: aws-actions/configure-aws-credentials@v4
        with:
          aws-access-key-id: ${{ "{{" }} secrets.AWS_ACCESS_KEY_ID {{ "}}" }}
          aws-secret-access-key: ${{ "{{" }} secrets.AWS_SECRET_ACCESS_KEY {{ "}}" }}
          aws-region: {{ aws_region }}

      - name: Login to ECR
        uses: aws-actions/amazon-ecr-login@v2

      - name: Build and push image
        run: |
          docker build -t ${{ "{{" }} secrets.ECR_REPO {{ "}}" }}:$GITHUB_SHA .
          docker push ${{ "{{" }} secrets.ECR_REPO {{ "}}" }}:$GITHUB_SHA

      - name: Terraform apply
        run: |
          cd terraform
          terraform init
          terraform apply -auto-approve

      - name: Rollout restart
        run: kubectl rollout restart deployment/{{ app_name }}
      {% endif %}